{
  "name": "attendance-connector-hikvision",
  "version": "1.0.0",
  "description": "Hikvision ISAPI connector - syncs to PunchPay cloud",
  "main": "hikvision-connector.js",
  "bin": "hikvision-connector.js",
  "scripts": {
    "start": "node hikvision-connector.js",
    "build:win": "pkg . --targets node18-win-x64 --output dist/connector-hik.exe",
    "build:mac": "pkg . --targets node18-macos-x64 --output dist/connector-hik-mac"
  },
  "pkg": {
    "scripts": "hikvision-connector.js",
    "assets": [],
    "outputPath": "dist"
  },
  "dependencies": {},
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
