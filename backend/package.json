{
  "name": "attendance-saas-backend",
  "version": "1.0.0",
  "description": "SaaS attendance and payroll system API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "postinstall": "patch-package",
    "migrate": "node ./scripts/migrate.js",
    "repair:salary-payments": "node ./scripts/repair-salary-payments-table.js",
    "seed": "node ./scripts/seed.js",
    "seed:testdata": "node ./scripts/generate-test-data.js",
    "seed:testdata:fresh": "npm run migrate && npm run seed:testdata",
    "connector": "node ./scripts/biometric-connector.js",
    "connector:once": "node ./scripts/biometric-connector.js --once",
    "import:employees:excel": "node ./scripts/import-employees-from-xlsx.js",
    "whatsapp:daily": "node ./scripts/run-whatsapp-daily-job.js",
    "mobile:qr-cleanup": "node ./scripts/run-mobile-qr-cleanup.js",
    "face:models": "node ./scripts/download-face-models.js",
    "test": "node --test test/*.test.js",
    "test:mobile": "node ./scripts/test-mobile-punch.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "attendance",
    "payroll",
    "saas",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "bcrypt": "^5.1.1",
    "canvas": "^3.2.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.12.0",
    "razorpay": "^2.9.6",
    "xlsx": "^0.18.5",
    "zk-attendance-sdk": "^2.1.0",
    "zklib-js": "^1.3.5"
  },
  "devDependencies": {
    "patch-package": "^8.0.1"
  }
}
