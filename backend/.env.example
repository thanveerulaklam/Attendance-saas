# server.js sets process.env.TZ = Asia/Kolkata so Node Date operations align with IST.
NODE_ENV=development
PORT=3000

# Frontend / CORS
# For local dev, keep http://localhost:5173
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance_saas
DB_USER=postgres
DB_PASSWORD=your_password
DB_POOL_MAX=20

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Rate limit: max login/register attempts per IP per 15 min (default 50)
# AUTH_RATE_LIMIT_MAX=50

# Admin rate limiting: max admin API calls per IP per 15 min (default 400; page load uses several)
# Controls /api/admin/* routes
# ADMIN_RATE_LIMIT_MAX=400

# Company timezone for shift start and late calculations (default Asia/Kolkata for Indian deployments)
# Server may run in UTC; shift "9:30" is interpreted as 9:30 AM in this timezone
# COMPANY_TIMEZONE=Asia/Kolkata

# Super Admin portal (/admin, /api/admin/*): shared secret sent as X-Approval-Secret header.
# Production: required, min 32 chars — generate with: openssl rand -hex 32
ADMIN_APPROVAL_SECRET=your-secret-to-approve-new-companies

# Optional: comma-separated IPs allowed to call /api/admin (your home/office/VPN egress IPs).
# When unset, any IP may attempt auth (still needs the secret). Example:
# ADMIN_IP_ALLOWLIST=203.0.113.10,127.0.0.1

# Failed admin auth attempts per IP per 15 minutes (default 10). Slows secret guessing.
# ADMIN_FAILED_AUTH_MAX=10

# Biometric device connector (eSSL SilkBio 101 TC / ZKTeco protocol)
BIOMETRIC_DEVICE_IP=192.168.1.50
BIOMETRIC_DEVICE_PORT=4370
DEVICE_API_KEY=
BACKEND_URL=http://localhost:3000
BIOMETRIC_POLL_INTERVAL_MS=60000

# WhatsApp Cloud API (Meta) — daily attendance template messages
# Token: Business Manager → System users → Generate token (whatsapp_business_messaging).
# Phone number ID: Meta Developers → PunchPay → WhatsApp → API Setup.
WHATSAPP_ENABLED=false
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=daily_attendance_update
WHATSAPP_TEMPLATE_LANG=en
# Hourly tick (top of each hour); per-company send hour is whatsapp_send_time in DB.
WHATSAPP_HOURLY_CRON=0 * * * *
WHATSAPP_DAILY_TIMEZONE=Asia/Kolkata

# Mobile attendance (QR + geofence)
MOBILE_QR_TTL_SECONDS=120
MOBILE_MAX_GPS_ACCURACY_M=80
MOBILE_DEFAULT_GEOFENCE_RADIUS_M=100
MOBILE_MAX_GEOFENCE_RADIUS_M=500
MOBILE_PUNCH_RATE_LIMIT_MAX=10
# Nightly purge of expired QR nonces (set MOBILE_QR_CLEANUP_ENABLED=false to disable)
MOBILE_QR_CLEANUP_CRON=0 3 * * *
MOBILE_QR_CLEANUP_TIMEZONE=Asia/Kolkata
MOBILE_QR_CLEANUP_OLDER_THAN_DAYS=1

# Face attendance office tablet APK served from Company Settings.
# Default: backend/downloads/PunchPay-Kiosk.apk (copy after EAS build).
# KIOSK_APK_PATH=/absolute/path/to/PunchPay-Kiosk.apk
KIOSK_FACE_MATCH_THRESHOLD=0.55
KIOSK_EMPLOYEE_COOLDOWN_SECONDS=60
KIOSK_PUNCH_RATE_LIMIT_MAX=30
