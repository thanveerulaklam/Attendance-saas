# Server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance_saas
DB_USER=postgres
DB_PASSWORD=your_password
DB_POOL_MAX=20

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Rate limit: max login/register attempts per IP per 15 min (default 50)
# AUTH_RATE_LIMIT_MAX=50

# Company approval (after client pays): required for POST /api/admin/approve-company
ADMIN_APPROVAL_SECRET=your-secret-to-approve-new-companies

# Biometric device connector (eSSL SilkBio 101 TC / ZKTeco protocol)
BIOMETRIC_DEVICE_IP=192.168.1.50
BIOMETRIC_DEVICE_PORT=4370
DEVICE_API_KEY=
BACKEND_URL=http://localhost:3000
BIOMETRIC_POLL_INTERVAL_MS=60000
